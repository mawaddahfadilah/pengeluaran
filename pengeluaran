import tkinter as tk
from tkinter import messagebox
import csv
import os
from datetime import datetime
import matplotlib.pyplot as plt
from collections import defaultdict

DATA_FILE = 'data.csv'

# Simpan data ke CSV
def simpan_data(tanggal, deskripsi, jumlah, kategori):
    file_baru = not os.path.exists(DATA_FILE)
    with open(DATA_FILE, mode='a', newline='') as file:
        writer = csv.writer(file)
        if file_baru:
            writer.writerow(['Tanggal', 'Deskripsi', 'Jumlah', 'Kategori'])
        writer.writerow([tanggal, deskripsi, jumlah, kategori])

# Baca data dari CSV
def baca_data():
    if not os.path.exists(DATA_FILE):
        return []
    with open(DATA_FILE, newline='') as file:
        reader = csv.DictReader(file)
        return list(reader)

# Tambah data dari form
def tambah_data():
    tanggal = ent_tanggal.get()
    deskripsi = ent_deskripsi.get()
    jumlah = ent_jumlah.get()
    kategori = ent_kategori.get()

    if not (tanggal and deskripsi and jumlah and kategori):
        messagebox.showwarning("Peringatan", "Semua field harus diisi!")
        return

    try:
        int(jumlah.replace(",", "").replace(".", ""))
    except ValueError:
        messagebox.showerror("Error", "Jumlah harus angka!")
        return

    simpan_data(tanggal, deskripsi, jumlah, kategori)
    tampilkan_data()
    ent_deskripsi.delete(0, tk.END)
    ent_jumlah.delete(0, tk.END)
    ent_kategori.delete(0, tk.END)

# Tampilkan data di layar
def tampilkan_data(data=None):
    if data is None:
        data = baca_data()
    listbox.delete(0, tk.END)
    for row in data:
        listbox.insert(tk.END, f"{row['Tanggal']} | {row['Kategori']} | {row['Deskripsi']} - Rp {row['Jumlah']}")

# Filter data
def filter_data():
    tanggal_filter = ent_filter_tanggal.get()
    kategori_filter = ent_filter_kategori.get()
    data = baca_data()

    hasil = []
    for row in data:
        if (not tanggal_filter or tanggal_filter in row['Tanggal']) and \
           (not kategori_filter or kategori_filter.lower() in row['Kategori'].lower()):
            hasil.append(row)

    tampilkan_data(hasil)

# Reset filter
def reset_filter():
    ent_filter_tanggal.delete(0, tk.END)
    ent_filter_kategori.delete(0, tk.END)
    tampilkan_data()

# Tampilkan grafik
def tampilkan_grafik():
    data = baca_data()
    if not data:
        messagebox.showinfo("Info", "Belum ada data.")
        return

    total_per_kategori = defaultdict(int)
    for row in data:
        try:
            jumlah = int(row['Jumlah'].replace(",", "").replace(".", ""))
            total_per_kategori[row['Kategori']] += jumlah
        except:
            continue

    kategori = list(total_per_kategori.keys())
    jumlah = list(total_per_kategori.values())

    plt.figure(figsize=(6, 4))
    plt.bar(kategori, jumlah, color='skyblue')
    plt.title('Pengeluaran per Kategori')
    plt.xlabel('Kategori')
    plt.ylabel('Jumlah (Rp)')
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

# UI
root = tk.Tk()
root.title("Aplikasi Catat Pengeluaran")

# Form input
tk.Label(root, text="Tanggal (YYYY-MM-DD):").pack()
ent_tanggal = tk.Entry(root)
ent_tanggal.pack()
ent_tanggal.insert(0, datetime.now().strftime('%Y-%m-%d'))

tk.Label(root, text="Deskripsi:").pack()
ent_deskripsi = tk.Entry(root)
ent_deskripsi.pack()

tk.Label(root, text="Jumlah (Rp):").pack()
ent_jumlah = tk.Entry(root)
ent_jumlah.pack()

tk.Label(root, text="Kategori:").pack()
ent_kategori = tk.Entry(root)
ent_kategori.pack()

tk.Button(root, text="Tambah", command=tambah_data).pack(pady=5)

# Filter
tk.Label(root, text="\nFilter").pack()
filter_frame = tk.Frame(root)
filter_frame.pack()

ent_filter_tanggal = tk.Entry(filter_frame, width=12)
ent_filter_tanggal.insert(0, "YYYY-MM-DD")
ent_filter_tanggal.pack(side=tk.LEFT)

ent_filter_kategori = tk.Entry(filter_frame, width=12)
ent_filter_kategori.insert(0, "Kategori")
ent_filter_kategori.pack(side=tk.LEFT)

tk.Button(filter_frame, text="Terapkan Filter", command=filter_data).pack(side=tk.LEFT, padx=2)
tk.Button(filter_frame, text="Reset", command=reset_filter).pack(side=tk.LEFT)

# Listbox untuk tampilkan data
listbox = tk.Listbox(root, width=60)
listbox.pack(pady=10)

# Tombol untuk tampilkan grafik
tk.Button(root, text="Tampilkan Grafik", command=tampilkan_grafik).pack()

# Tampilkan semua data awal
tampilkan_data()

root.mainloop()
